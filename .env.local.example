# App branding (shown in header, page titles)
NEXT_PUBLIC_APP_NAME=Meeting Whisperer Admin

# Backend API URL (your agent app's admin API)
NEXT_PUBLIC_API_URL=http://localhost:8005

# Dashboard Supabase V2 (login, profiles, dashboard-specific data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key

# Backend Supabase V2 (auth for backend API calls — same project in V2)
NEXT_PUBLIC_MW_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_MW_SUPABASE_ANON_KEY=sb_publishable_your-key
