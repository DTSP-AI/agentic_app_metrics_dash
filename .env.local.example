# App branding (shown in header, page titles)
NEXT_PUBLIC_APP_NAME=Meeting Whisperer Admin

# Backend API URL (your agent app's admin API)
NEXT_PUBLIC_API_URL=http://localhost:8005

# Dashboard Supabase (login, profiles, dashboard-specific data)
NEXT_PUBLIC_SUPABASE_URL=https://your-dashboard-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-dashboard-anon-key

# Backend Supabase (JWT auth for backend API calls — the agent app's Supabase)
NEXT_PUBLIC_MW_SUPABASE_URL=https://your-agent-app.supabase.co
NEXT_PUBLIC_MW_SUPABASE_ANON_KEY=your-agent-app-anon-key
